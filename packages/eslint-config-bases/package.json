{
  "name": "@belgattitude/eslint-config-bases",
  "type": "module",
  "version": "8.9.0",
  "author": {
    "name": "Vanvelthem Sébastien",
    "url": "https://github.com/belgattitude"
  },
  "license": "MIT",
  "homepage": "https://github.com/belgattitude/shared-dx/tree/main/packages/eslint-config-bases",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/belgattitude/shared-dx.git",
    "directory": "packages/eslint-config-bases"
  },
  "keywords": [
    "eslint",
    "eslint-config"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "default": "./src/index.mjs"
    },
    "./helpers": {
      "default": "./src/helpers/index.mjs"
    },
    "./import-x": {
      "default": "./src/bases/import-x.mjs"
    },
    "./perfectionist": {
      "default": "./src/bases/perfectionist.mjs"
    },
    "./perfectionist-jsx": {
      "default": "./src/bases/perfectionist-jsx.mjs"
    },
    "./playwright": {
      "default": "./src/bases/playwright.mjs"
    },
    "./prettier-config": {
      "default": "./src/bases/prettier-config.mjs"
    },
    "./prettier-plugin": {
      "default": "./src/bases/prettier-plugin.mjs"
    },
    "./performance": {
      "default": "./src/bases/performance.mjs"
    },
    "./react": {
      "default": "./src/bases/react.mjs"
    },
    "./react-query": {
      "default": "./src/bases/react-query.mjs"
    },
    "./react-testing-library": {
      "default": "./src/bases/react-testing-library.mjs"
    },
    "./regexp": {
      "default": "./src/bases/regexp.mjs"
    },
    "./simple-import-sort": {
      "default": "./src/bases/simple-import-sort.mjs"
    },
    "./sonar": {
      "default": "./src/bases/sonar.mjs"
    },
    "./storybook": {
      "default": "./src/bases/storybook.mjs"
    },
    "./typescript": {
      "default": "./src/bases/typescript.mjs"
    },
    "./vitest": {
      "default": "./src/bases/vitest.mjs"
    }
  },
  "files": [
    "src"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "clean": "rimraf ./dist ./coverage ./tsconfig.tsbuildinfo",
    "lint": "TIMING=1 eslint . --cache --cache-location ../../.cache/eslint/eslint-config-bases.eslintcache",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "check-dist": "es-check -v"
  },
  "peerDependencies": {
    "eslint": "^9.39.2",
    "eslint-plugin-storybook": "^10.1.6",
    "prettier": ">=3.2.0 <5.0.0",
    "react": ">=19.1.0",
    "react-dom": ">=19.1.0",
    "typescript": "^5.5.4"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-storybook": {
      "optional": true
    },
    "prettier": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@eslint/js": "^9.39.2",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@typescript-eslint/typescript-estree": "^8.57.0",
    "@typescript-eslint/utils": "^8.57.0",
    "@vitest/eslint-plugin": "^1.6.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-oxfmt": "^0.1.1",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^3.0.6",
    "eslint-plugin-testing-library": "^7.16.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "7.7.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.0.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "es-check": "9.6.2",
    "eslint": "9.39.2",
    "eslint-plugin-mdx": "3.7.0",
    "eslint-plugin-storybook": "10.2.8",
    "prettier": "3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rimraf": "6.1.3",
    "storybook": "10.2.8",
    "tsdown": "0.20.3",
    "typescript": "5.9.3"
  }
}
