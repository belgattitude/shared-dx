{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@belgattitude/eslint-config-bases",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "incremental": true,
    "allowJs": true,
    "checkJs": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "module": "node16",
  },
  "exclude": ["dist", "build"],
  "include": [".prettierrc.mjs", "**/*.ts", "**/*.js", "**/*.cjs", "**/*.mjs", "**/*.json"]
}
