{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@belgattitude/eslint-config-bases",
  "compilerOptions": {
    "incremental": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": [".prettierrc.mjs", "**/*.ts", "**/*.js", "**/*.cjs", "**/*.mjs", "**/*.json"],
  "exclude": ["dist", "build"]
}
