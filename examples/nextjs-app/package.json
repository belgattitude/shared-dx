{
  "name": "@examples/nextjs-app",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev-no-tls": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 next dev",
    "build": "next build",
    "build-fast": "cross-env NEXTJS_PROD_SOURCE_MAPS=false NEXTJS_IGNORE_TYPECHECK=true NEXTJS_IGNORE_LINT=true next build --no-lint",
    "start": "next start",
    "lint": "next typegen && cross-env TIMING=1 eslint . --ext .ts,.tsx,.js,.jsx,.mjs,.cjs,.mts,.cts --cache --cache-location ../../.cache/web.eslintcache",
    "test": "vitest run",
    "test-unit": "vitest run",
    "typecheck": "next typegen && tsc --project ./tsconfig.json --noEmit",
    "clean": "rimraf ./.next ./out ./coverage ./tsconfig.tsbuildinfo ./node_modules/.cache",
    "bundle-analyze": "cross-env ANALYZE=true NEXTJS_IGNORE_TYPECHECK=1 NEXTJS_IGNORE_LINT=1 next build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "browserslist": [
    "chrome 100"
  ],
  "dependencies": {
    "@httpx/assert": "0.16.9",
    "@httpx/compress": "0.3.12",
    "@httpx/dsn-parser": "1.9.9",
    "@httpx/exception": "3.1.9",
    "@httpx/lru": "0.13.2",
    "@httpx/memo-intl": "1.4.10",
    "@httpx/plain-object": "2.1.8",
    "@httpx/treeu": "0.5.8",
    "@next/mdx": "16.2.2",
    "@tanstack/query-core": "5.96.2",
    "@tanstack/react-query": "5.96.2",
    "@vercel/og": "0.11.1",
    "clsx": "2.1.1",
    "graphql": "16.13.2",
    "ky": "1.14.3",
    "mdx": "0.3.1",
    "next": "16.2.2",
    "next-secure-headers": "2.2.0",
    "picocolors": "1.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.5",
    "tailwind-merge": "3.5.0",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@belgattitude/eslint-config-bases": "workspace:^",
    "@next/bundle-analyzer": "16.2.2",
    "@storybook/addon-docs": "10.3.4",
    "@storybook/addon-links": "10.3.4",
    "@storybook/nextjs": "10.3.4",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/postcss": "4.2.2",
    "@tailwindcss/typography": "0.5.19",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/mdx": "2.0.13",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "autoprefixer": "10.4.27",
    "cross-env": "10.1.0",
    "dotenv-flow-cli": "1.1.1",
    "eslint": "8.57.1",
    "eslint-plugin-mdx": "3.7.0",
    "eslint-plugin-storybook": "10.3.4",
    "graphql-config": "5.1.6",
    "postcss": "8.5.8",
    "postcss-loader": "8.2.1",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "sass": "1.99.0",
    "storybook": "10.3.4",
    "tailwindcss": "4.2.2",
    "type-fest": "5.5.0",
    "typescript": "6.0.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.2",
    "webpack": "5.105.4"
  }
}
