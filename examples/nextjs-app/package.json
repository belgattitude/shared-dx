{
  "name": "@examples/nextjs-app",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev-no-tls": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 next dev",
    "build": "next build",
    "build-fast": "cross-env NEXTJS_PROD_SOURCE_MAPS=false NEXTJS_IGNORE_TYPECHECK=true NEXTJS_IGNORE_LINT=true next build --no-lint",
    "start": "next start",
    "lint": "next typegen && cross-env TIMING=1 eslint . --ext .ts,.tsx,.js,.jsx,.mjs,.cjs,.mts,.cts --cache --cache-location ../../.cache/web.eslintcache",
    "test": "vitest run",
    "test-unit": "vitest run",
    "typecheck": "next typegen && tsc --project ./tsconfig.json --noEmit",
    "clean": "rimraf ./.next ./out ./coverage ./tsconfig.tsbuildinfo ./node_modules/.cache",
    "bundle-analyze": "cross-env ANALYZE=true NEXTJS_IGNORE_TYPECHECK=1 NEXTJS_IGNORE_LINT=1 next build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "browserslist": [
    "chrome 100"
  ],
  "dependencies": {
    "@httpx/assert": "0.17.1",
    "@httpx/compress": "0.3.13",
    "@httpx/dsn-parser": "1.9.11",
    "@httpx/exception": "3.1.11",
    "@httpx/lru": "0.14.0",
    "@httpx/memo-intl": "1.4.12",
    "@httpx/plain-object": "2.1.11",
    "@httpx/treeu": "0.6.1",
    "@next/mdx": "16.2.9",
    "@tanstack/query-core": "5.101.1",
    "@tanstack/react-query": "5.101.1",
    "@vercel/og": "0.11.1",
    "clsx": "2.1.1",
    "graphql": "17.0.1",
    "ky": "2.0.2",
    "mdx": "0.3.1",
    "next": "16.2.9",
    "next-secure-headers": "2.2.0",
    "picocolors": "1.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.35.2",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@belgattitude/eslint-config-bases": "workspace:^",
    "@next/bundle-analyzer": "16.2.9",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-links": "10.4.6",
    "@storybook/nextjs": "10.4.6",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/postcss": "4.3.1",
    "@tailwindcss/typography": "0.5.20",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/mdx": "2.0.14",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.5.2",
    "cross-env": "10.1.0",
    "dotenv-flow-cli": "1.1.1",
    "eslint": "8.57.1",
    "eslint-plugin-mdx": "3.8.1",
    "eslint-plugin-storybook": "10.4.6",
    "graphql-config": "5.1.6",
    "postcss": "8.5.15",
    "postcss-loader": "8.2.1",
    "prettier": "3.9.0",
    "rimraf": "6.1.3",
    "sass": "1.101.0",
    "storybook": "10.4.6",
    "tailwindcss": "4.3.1",
    "type-fest": "5.7.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "webpack": "5.108.1"
  }
}
